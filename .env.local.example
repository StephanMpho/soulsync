NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Base URL used to build the shareable invite link (soulsync.app/invite/<token>).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

ANTHROPIC_API_KEY=

# Supabase Dashboard -> Project Settings -> API -> "service_role" secret.
# Server-only: used exclusively by the cron route to read/write across all
# couples. Never expose this to the browser (no NEXT_PUBLIC_ prefix).
SUPABASE_SERVICE_ROLE_KEY=

# Generate via web-push's generateVAPIDKeys() (already installed as a dependency).
# NEXT_PUBLIC_ copy is needed because the browser must pass the public key to
# pushManager.subscribe().
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Shared secret checked by /api/cron/daily — generate any random string
# (e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`)
# and also set it as a Vercel project env var so Vercel's cron invocations
# authenticate automatically.
CRON_SECRET=
